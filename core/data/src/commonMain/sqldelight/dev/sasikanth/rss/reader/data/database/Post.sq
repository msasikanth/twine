  post.postDate > :postsAfter AND
  post.createdAt < :postsUpperBound AND
  (post.flags & 4) = 0 AND
  ((:isSourceIdsEmpty AND feed.hideFromAllFeeds = 0) OR post.sourceId IN :sourceIds) AND
  feed.isDeleted = 0 AND
  (
    (:unreadOnly IS NULL OR ((post.flags & 2) != 0) != :unreadOnly)
    OR post.id IN :sessionPostIds
  )
ORDER BY
  post.createdAt ASC,
  post.postDate ASC,
  post.id ASC
LIMIT :limit OFFSET :offset;

nonFeaturedPostsCount:
SELECT COUNT(post.id) FROM post
INNER JOIN feed ON post.sourceId == feed.id
WHERE
  post.id NOT IN (
    SELECT p2.id FROM post p2
    INNER JOIN feed f2 ON p2.sourceId = f2.id
    WHERE
      p2.imageUrl IS NOT NULL AND
      p2.postDate > :featuredPostsAfter AND
      p2.postDate > :postsAfter AND
      p2.createdAt < :postsUpperBound AND
      (p2.flags & 4) = 0 AND
      ((:isSourceIdsEmpty AND f2.hideFromAllFeeds = 0) OR p2.sourceId IN :sourceIds) AND
      f2.isDeleted = 0 AND
      (
        (:unreadOnly IS NULL OR ((p2.flags & 2) != 0) != :unreadOnly)
        OR p2.id IN :sessionPostIds
      )
    ORDER BY
      CASE WHEN :postsSortOrder = 'Latest' THEN p2.postDate END DESC,
      CASE WHEN :postsSortOrder = 'Latest' THEN p2.createdAt END DESC,
      CASE WHEN :postsSortOrder = 'Oldest' THEN p2.postDate END ASC,
      CASE WHEN :postsSortOrder = 'Oldest' THEN p2.createdAt END ASC,
      CASE WHEN :postsSortOrder = 'AddedLatest' THEN p2.createdAt END DESC,
      CASE WHEN :postsSortOrder = 'AddedLatest' THEN p2.postDate END DESC,
      CASE WHEN :postsSortOrder = 'AddedOldest' THEN p2.createdAt END ASC,
      CASE WHEN :postsSortOrder = 'AddedOldest' THEN p2.postDate END ASC
    LIMIT :numberOfFeaturedPosts
  ) AND
  ((:isSourceIdsEmpty AND feed.hideFromAllFeeds = 0) OR post.sourceId IN :sourceIds) AND
  (post.flags & 4) == 0 AND
  feed.isDeleted = 0 AND
  (
    (:unreadOnly IS NULL OR ((post.flags & 2) != 0) != :unreadOnly)
    OR post.id IN :sessionPostIds
  ) AND
  post.postDate > :postsAfter AND
  post.createdAt < :postsUpperBound;

updateBookmarkStatus:
UPDATE post SET flags = CASE WHEN :bookmarked = 1 THEN flags | 1 ELSE flags & ~1 END, updatedAt = :updatedAt WHERE id = :id;

updatePostsBookmarkStatus:
UPDATE post SET flags = CASE WHEN :bookmarked = 1 THEN flags | 1 ELSE flags & ~1 END, updatedAt = :updatedAt WHERE id IN :ids;

updateReadStatus:
UPDATE post SET flags = CASE WHEN :read = 1 THEN flags | 2 ELSE flags & ~2 END, updatedAt = :updatedAt WHERE id = :id;

updatePostsReadStatus:
UPDATE post SET flags = CASE WHEN :read = 1 THEN flags | 2 ELSE flags & ~2 END, updatedAt = :updatedAt WHERE id IN :ids;

updateSeedColor:
UPDATE post SET seedColor = :seedColor WHERE id = :id;

updateAudioProgress:
UPDATE post SET audioProgress = :audioProgress, audioDuration = :audioDuration WHERE id = :id;

deleteReadPosts:
DELETE FROM post
WHERE (post.flags & 2) != 0 AND post.postDate < :before
RETURNING post.sourceId;

deleteReadPostsForFeed:
DELETE FROM post
WHERE sourceId = :feedId AND (post.flags & 2) != 0 AND post.postDate < :before;

markPostsAsReadForFeed:
UPDATE post
SET flags = flags | 2, updatedAt = :updatedAt
WHERE sourceId = :sourceId
  AND postDate > :after
  AND (flags & 2) == 0
RETURNING id;

markAllPostsAsRead:
UPDATE post
SET flags = flags | 2, updatedAt = :updatedAt
WHERE postDate > :after
  AND (flags & 2) == 0
RETURNING id;

postsByIds:
SELECT * FROM post
WHERE id IN :ids;

postById:
SELECT * FROM post
WHERE post.id = :id;

resolvedPostById:
SELECT
  post.id AS id,
  post.sourceId AS sourceId,
  post.title AS title,
  post.description AS description,
  post.imageUrl AS imageUrl,
  post.audioUrl AS audioUrl,
  post.postDate AS postDate,
  post.createdAt AS createdAt,
  post.link AS link,
  post.commentsLink AS commentsLink,
  post.flags AS flags,
  post.remoteId AS remoteId,
  feed.name AS feedName,
  feed.icon AS feedIcon,
  feed.homepageLink AS feedHomepageLink,
  feed.alwaysFetchSourceArticle AS alwaysFetchSourceArticle,
  feed.showFeedFavIcon AS showFeedFavIcon,
  pc.feedContentReadingTime AS feedContentReadingTime,
  pc.articleContentReadingTime AS articleContentReadingTime,
  post.seedColor AS seedColor,
  post.audioProgress AS audioProgress,
  post.audioDuration AS audioDuration
FROM post
INNER JOIN feed ON post.sourceId = feed.id
LEFT JOIN postContent pc ON post.id = pc.id
WHERE post.id = :id;

post:
SELECT * FROM post
WHERE post.id = :id AND post.sourceId = :sourceId;

postsWithImagesAndNoSeedColor:
SELECT
  post.id AS id,
  post.sourceId AS sourceId,
  post.title AS title,
  post.description AS description,
  post.imageUrl AS imageUrl,
  post.audioUrl AS audioUrl,
  post.postDate AS postDate,
  post.createdAt AS createdAt,
  post.link AS link,
  post.commentsLink AS commentsLink,
  post.flags AS flags,
  post.remoteId AS remoteId,
  feed.name AS feedName,
  feed.icon AS feedIcon,
  feed.homepageLink AS feedHomepageLink,
  feed.alwaysFetchSourceArticle AS alwaysFetchSourceArticle,
  feed.showFeedFavIcon AS showFeedFavIcon,
  pc.feedContentReadingTime AS feedContentReadingTime,
  pc.articleContentReadingTime AS articleContentReadingTime,
  post.seedColor AS seedColor,
  post.audioProgress AS audioProgress,
  post.audioDuration AS audioDuration
FROM post
INNER JOIN feed ON post.sourceId = feed.id
LEFT JOIN postContent pc ON post.id = pc.id
WHERE post.imageUrl IS NOT NULL AND post.seedColor IS NULL
ORDER BY post.postDate DESC
LIMIT :limit;

postByRemoteId:
SELECT * FROM post
WHERE remoteId = :remoteId;

postsByRemoteIds:
SELECT * FROM post
WHERE remoteId IN :remoteIds;

postByLink:
SELECT * FROM post
WHERE link = :link;

postsByLinks:
SELECT * FROM post
WHERE link IN :links;

postPositionLatest:
SELECT COUNT(*) FROM post
INNER JOIN feed ON post.sourceId = feed.id
WHERE
  ((:isSourceIdsEmpty AND feed.hideFromAllFeeds = 0) OR post.sourceId IN :sourceIds) AND
  (post.flags & 4) == 0 AND
  feed.isDeleted = 0 AND
  (
    (:unreadOnly IS NULL OR ((post.flags & 2) != 0) != :unreadOnly)
    OR post.id IN :sessionPostIds
  ) AND
  post.postDate > :postsAfter AND
  post.createdAt < :postsUpperBound AND
  (post.postDate > :postDate OR (post.postDate = :postDate AND (post.createdAt > :postCreatedAt OR (post.createdAt = :postCreatedAt AND post.id > :postId))));

