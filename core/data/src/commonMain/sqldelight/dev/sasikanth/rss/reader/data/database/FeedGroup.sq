  fg.id,
  fg.name,
  fgm.feedIds,
  COALESCE(fgm.feedHomepageLinks, '') AS feedHomepageLinks,
  COALESCE(fgm.feedIconLinks, '') AS feedIconLinks,
  COALESCE(fgm.feedShowFavIconSettings, '') AS feedShowFavIconSettings,
  fg.createdAt,
  fg.updatedAt,
  fg.pinnedAt,
  fg.remoteId
FROM feedGroup fg
LEFT JOIN feed_group_metadata fgm ON fg.id = fgm.feedGroupId
WHERE fg.id IN :ids AND fg.isDeleted = 0;

updatedPinnedPosition:
UPDATE feedGroup SET pinnedPosition = :pinnedPosition, updatedAt = :updatedAt WHERE id = :id;

