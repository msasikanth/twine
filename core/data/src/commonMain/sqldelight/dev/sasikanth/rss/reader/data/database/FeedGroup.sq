WHERE fg.isDeleted = 0;

createGroup:
INSERT INTO feedGroup(id, name, createdAt, updatedAt)
VALUES (:id, :name, :createdAt, :updatedAt)
ON CONFLICT(id) DO UPDATE SET
  name = excluded.name,
  updatedAt = excluded.updatedAt,
  isDeleted = 0;

updateGroupName:
UPDATE feedGroup SET name = :name, updatedAt = :updatedAt WHERE id = :id;

updateUpdatedAt:
UPDATE feedGroup SET updatedAt = :updatedAt WHERE id = :id;

markAsDeleted:
UPDATE feedGroup SET isDeleted = 1, updatedAt = :updatedAt WHERE id = :id;

remove:
DELETE FROM feedGroup WHERE id = :id;

updatePinnedAt:
UPDATE feedGroup SET pinnedAt = :pinnedAt, pinnedPosition = 0.0, updatedAt = :updatedAt WHERE id = :id;

group:
WITH ranked_feeds AS (
  SELECT
    gf.feedGroupId,
    gf.feedId,
    f.homepageLink,
    f.icon,
    CASE
      WHEN f.showFeedFavIcon IS NULL THEN 'null'
      WHEN f.showFeedFavIcon = 1 THEN 'true'
      ELSE 'false'
    END AS showFeedFavIconStr,
    ROW_NUMBER() OVER (PARTITION BY gf.feedGroupId ORDER BY gf.rowid) AS rn
  FROM feedGroupFeed gf
  JOIN feed f ON gf.feedId = f.id
  WHERE f.isDeleted = 0
),
feed_group_metadata AS (
  SELECT
    feedGroupId,
    GROUP_CONCAT(feedId, '::') AS feedIds,
    COALESCE(GROUP_CONCAT(CASE WHEN rn <= 4 THEN homepageLink END, '::'), '') AS feedHomepageLinks,
    COALESCE(GROUP_CONCAT(CASE WHEN rn <= 4 THEN icon END, '::'), '') AS feedIconLinks,
    COALESCE(GROUP_CONCAT(CASE WHEN rn <= 4 THEN showFeedFavIconStr END, '::'), '') AS feedShowFavIconSettings
  FROM ranked_feeds
  GROUP BY feedGroupId
)
SELECT
  fg.id,
  fg.name,
  fgm.feedIds,
  COALESCE(fgm.feedHomepageLinks, '') AS feedHomepageLinks,
  COALESCE(fgm.feedIconLinks, '') AS feedIconLinks,
  COALESCE(fgm.feedShowFavIconSettings, '') AS feedShowFavIconSettings,
  fg.createdAt,
  fg.updatedAt,
  fg.pinnedAt,
  fg.pinnedPosition,
  fg.isDeleted,
  fg.remoteId
FROM feedGroup fg
LEFT JOIN feed_group_metadata fgm ON fg.id = fgm.feedGroupId
WHERE fg.id = :id AND fg.isDeleted = 0;

