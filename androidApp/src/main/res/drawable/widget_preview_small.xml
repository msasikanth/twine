<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <size
                android:width="160dp"
                android:height="160dp" />
            <corners android:radius="24dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Post image -->
    <item
        android:gravity="top|fill_horizontal"
        android:height="88dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#E1E7E1" />
        </shape>
    </item>

    <!-- Post title -->
    <item
        android:gravity="top|fill_horizontal"
        android:height="9dp"
        android:left="12dp"
        android:right="24dp"
        android:top="106dp">
        <shape android:shape="rectangle">
            <corners android:radius="99dp" />
            <solid android:color="#333A35" />
        </shape>
    </item>
    <item
        android:gravity="top|fill_horizontal"
        android:height="9dp"
        android:left="12dp"
        android:right="64dp"
        android:top="121dp">
        <shape android:shape="rectangle">
            <corners android:radius="99dp" />
            <solid android:color="#333A35" />
        </shape>
    </item>

    <!-- Feed icon and name -->
    <item
        android:bottom="12dp"
        android:gravity="bottom|left"
        android:height="12dp"
        android:left="12dp"
        android:width="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="3dp" />
            <solid android:color="#9AA69D" />
        </shape>
    </item>
    <item
        android:bottom="14dp"
        android:gravity="bottom|left"
        android:height="8dp"
        android:left="30dp"
        android:width="44dp">
        <shape android:shape="rectangle">
            <corners android:radius="99dp" />
            <solid android:color="#9AA69D" />
        </shape>
    </item>

    <!-- Pagination dots -->
    <item
        android:bottom="15dp"
        android:gravity="bottom|right"
        android:height="5dp"
        android:right="48dp"
        android:width="5dp">
        <shape android:shape="oval">
            <solid android:color="#333A35" />
        </shape>
    </item>
    <item
        android:bottom="15dp"
        android:gravity="bottom|right"
        android:height="5dp"
        android:right="39dp"
        android:width="5dp">
        <shape android:shape="oval">
            <solid android:color="#C6CFC8" />
        </shape>
    </item>
    <item
        android:bottom="15dp"
        android:gravity="bottom|right"
        android:height="5dp"
        android:right="30dp"
        android:width="5dp">
        <shape android:shape="oval">
            <solid android:color="#C6CFC8" />
        </shape>
    </item>
    <item
        android:bottom="15dp"
        android:gravity="bottom|right"
        android:height="5dp"
        android:right="21dp"
        android:width="5dp">
        <shape android:shape="oval">
            <solid android:color="#C6CFC8" />
        </shape>
    </item>
    <item
        android:bottom="15dp"
        android:gravity="bottom|right"
        android:height="5dp"
        android:right="12dp"
        android:width="5dp">
        <shape android:shape="oval">
            <solid android:color="#C6CFC8" />
        </shape>
    </item>
</layer-list>
